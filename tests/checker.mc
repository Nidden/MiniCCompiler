// ============================================================
//   МОЗАИКА XOR — статичный цветной узор (без обновления экрана).
//   УКНЦ (Электроника МС-0511), графический режим 320x264.
//
//   Сетка 20x22 ячеек по 16x12 пикселей (ровно весь экран 320x264).
//   Цвет ячейки = ((gx XOR gy) % 3) + 1 — классический «munching
//   squares»: точный, симметричный и нетривиальный плед. Каждая
//   ячейка заливается быстрым fill_rect (словами). Рисуется один
//   раз и замирает (while(1){}) — экран не перерисовывается.
// ============================================================

int main() {
    int gx;     // индекс столбца (0..19)
    int gy;     // индекс строки  (0..21)
    int col;    // цвет ячейки (1..3)

    cls(0);

    gy = 0;
    while (gy < 22) {
        gx = 0;
        while (gx < 20) {
            col = ((gx ^ gy) % 3) + 1;
            fill_rect(gx * 16, gy * 12, 16, 12, col);
            gx = gx + 1;
        }
        gy = gy + 1;
    }

    while (1) { }
    return 0;
}
