// ============================================================
//   ТРЕУГОЛЬНИК СЕРПИНСКОГО — точный фрактал, рисуется ОДИН раз.
//   Без перерисовки экрана, без vsync, без мандалы.
//
//   Классическое построение: в каждом треугольнике рисуем
//   ПЕРЕВЁРНУТЫЙ средний треугольник (соединяя середины сторон)
//   и рекурсивно уходим в три угловых. Каждое ребро рисуется
//   ровно один раз — математически чистый рисунок.
//   Цвет зависит от глубины — слои фрактала различимы.
//   Экран 320x264, цвета графики 0..3.
// ============================================================

// Рекурсивный шаг. Вершины: A — верх, B — низ-лево, C — низ-право.
void sierp(int ax, int ay, int bx, int by, int cx, int cy, int d) {
    int abx; int aby;     // середина A-B
    int acx; int acy;     // середина A-C
    int bcx; int bcy;     // середина B-C
    int col;

    if (d <= 0) return;

    abx = (ax + bx) / 2;  aby = (ay + by) / 2;
    acx = (ax + cx) / 2;  acy = (ay + cy) / 2;
    bcx = (bx + cx) / 2;  bcy = (by + cy) / 2;

    // цвет слоя: 3 -> 2 -> 1 по мере погружения (>=1)
    col = d - 1;
    if (col < 1) col = 1;
    if (col > 3) col = 3;

    // перевёрнутый средний треугольник
    line(abx, aby, acx, acy, col);
    line(acx, acy, bcx, bcy, col);
    line(bcx, bcy, abx, aby, col);

    // три угловых под-треугольника
    sierp(ax,  ay,  abx, aby, acx, acy, d - 1);
    sierp(abx, aby, bx,  by,  bcx, bcy, d - 1);
    sierp(acx, acy, bcx, bcy, cx,  cy,  d - 1);
}

int main() {
    int ax; int ay;       // верхняя вершина
    int bx; int by;       // нижняя левая
    int cx; int cy;       // нижняя правая

    init(0);
    cls(0);

    ax = 160; ay = 10;
    bx = 12;  by = 250;
    cx = 308; cy = 250;

    // внешний контур (самый светлый)
    line(ax, ay, bx, by, 3);
    line(bx, by, cx, cy, 3);
    line(cx, cy, ax, ay, 3);

    // фрактал: 5 уровней деления
    sierp(ax, ay, bx, by, cx, cy, 5);

    while (1) { }         // картинка статична — держим кадр
    return 0;
}
