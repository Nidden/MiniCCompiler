// ============================================================
//   ТОННЕЛЬ — статичная картинка БЕЗ обновления экрана.
//   УКНЦ (Электроника МС-0511), графический режим 320x264.
//
//   Рисуется ОДИН раз и замирает. Никакого цикла перерисовки —
//   экран после отрисовки не трогается совсем, мерцать нечему.
//
//   Чтобы не было видно даже самого процесса рисования, кадр
//   строится НЕ сотнями медленных линий по пикселям, а немногими
//   быстрыми примитивами: 16 вложенных прямоугольников (контур)
//   + 4 перспективных ребра из углов к центру. Это создаёт
//   иллюзию 3D-тоннеля. Появляется практически мгновенно.
//
//   Геометрия точная и симметричная:
//     рамка i:  x=10i, y=8i, w=320-20i, h=264-16i
//     → левая/правая границы симметричны относительно центра 160,
//       верх/низ — относительно 132. Цвет рамки циклически 1..3.
// ============================================================

int main() {
    int i;          // номер рамки
    int c;          // цвет рамки (1..3)

    cls(0);

    // ── вложенные прямоугольники (быстрый контур) ──
    i = 0;
    while (i < 16) {
        c = (i % 3) + 1;
        rect(10 * i, 8 * i, 320 - 20 * i, 264 - 16 * i, c);
        i = i + 1;
    }

    // ── перспективные рёбра из углов к центру (объём тоннеля) ──
    line(0,   0,   160, 132, 3);
    line(319, 0,   160, 132, 3);
    line(0,   263, 160, 132, 3);
    line(319, 263, 160, 132, 3);

    // картинка готова — замираем, экран больше не трогаем
    while (1) { }
    return 0;
}
