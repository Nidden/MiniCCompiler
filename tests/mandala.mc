// ============================================================
//   МИСТИЧЕСКАЯ РОЗА — статичная мандала (без анимации)
//   УКНЦ (Электроника МС-0511), графический режим 320x264.
//
//   N точек равномерно на окружности (координаты — точно через
//   таблицы sin256/cos256, угол 0..255 = полный круг, амплитуда
//   256). Соединяем КАЖДУЮ пару точек хордой. Цвет хорды задаёт
//   её «класс» d = расстояние между точками по кругу (1..N/2):
//   так на одной картинке проявляются вложенные звёздчатые
//   многоугольники {N/d}, окрашенные в три цвета.
//
//   Картинка рисуется ОДИН раз и замирает — экран не
//   перерисовывается, поэтому мерцания нет вообще.
// ============================================================

int main() {
    int n;          // число точек на окружности
    int cx, cy, R;  // центр и радиус
    int i, j;       // индексы точек
    int d;          // класс хорды (1..N/2)
    int col;        // цвет хорды (1..3)
    int ang;        // угол точки (0..255)
    int px[24];     // координаты точек — считаем один раз
    int py[24];

    cls(0);
    n  = 24;
    cx = 160;
    cy = 132;
    R  = 118;

    // ── вершины на окружности (точная тригонометрия) ──
    i = 0;
    while (i < n) {
        ang   = (i * 256) / n;
        px[i] = cx + cos256(ang) * R / 256;
        py[i] = cy + sin256(ang) * R / 256;
        i = i + 1;
    }

    // ── все хорды, цвет по классу → вложенные звёзды {n/d} ──
    i = 0;
    while (i < n) {
        j = i + 1;
        while (j < n) {
            d = j - i;
            if (d > n / 2) d = n - d;     // класс хорды: 1..n/2
            col = ((d - 1) % 3) + 1;      // три цвета по слоям
            line(px[i], py[i], px[j], py[j], col);
            j = j + 1;
        }
        i = i + 1;
    }

    // ── обрамляющая окружность ──
    circle(cx, cy, R, 3);

    // картинка готова — замираем, экран не трогаем (нет мерцания)
    while (1) { }
    return 0;
}
