// ============================================================
//   МАНДАЛА — анимированный звёздчатый многоугольник {n/k}
//   УКНЦ (Электроника МС-0511), графический режим 320x264.
//
//   Математика «точная»: вершины лежат на окружности, их
//   координаты считаются через таблицы sin256/cos256
//   (угол 0..255 = полный круг, амплитуда 256). Каждый кадр
//   соединяем вершину i с вершиной (i+k) mod n — получается
//   звезда {n/k}, которая вращается, пульсирует и морфится.
//
//   Управление (необязательно):
//     ↑ / ↓  — больше / меньше вершин   (8, 16, 32)
//     → / ←  — изменить шаг соединения k (2..12)
// ============================================================

int main() {
    int t;          // счётчик кадров (0..6143, период всех эффектов)
    int n;          // число вершин (делитель 256: 8/16/32)
    int kbase;      // базовый шаг соединения вершин
    int step;       // угловой шаг между соседними вершинами = 256/n
    int rot;        // текущий угол поворота
    int R;          // радиус мандалы (пульсирует)
    int k;          // текущий шаг (морфинг вокруг kbase)
    int col;        // цвет линий (циклически 1..3)
    int i;          // индекс вершины
    int a0, a1;     // углы концов отрезка
    int x0, y0, x1, y1;
    int key;

    cls(0);
    n     = 16;
    kbase = 6;
    t     = 0;

    while (1) {
        vsync();
        cls(0);

        // ── клавиатура (неблокирующая) ──
        key = getkey();
        if (key == 65) { n = n * 2; if (n > 32) n = 32; }              // ↑
        if (key == 66) { n = n / 2; if (n < 8)  n = 8;  }              // ↓
        if (key == 67) { kbase = kbase + 1; if (kbase > 12) kbase = 12; } // →
        if (key == 68) { kbase = kbase - 1; if (kbase < 2)  kbase = 2;  } // ←

        step = 256 / n;
        rot  = t & 255;

        // пульсация радиуса: 80 + 36*sin  →  диапазон 44..116
        R = 80 + sin256(t * 3) * 36 / 256;

        // морфинг шага: kbase + (0..2), медленно
        k = kbase + ((t / 48) % 3);

        // цвет линий циклически 1..3
        col = ((t / 12) % 3) + 1;

        // ── рисуем все рёбра звезды ──
        i = 0;
        while (i < n) {
            a0 = i * step + rot;
            a1 = ((i + k) % n) * step + rot;
            x0 = 160 + cos256(a0) * R / 256;
            y0 = 132 + sin256(a0) * R / 256;
            x1 = 160 + cos256(a1) * R / 256;
            y1 = 132 + sin256(a1) * R / 256;
            line(x0, y0, x1, y1, col);
            i = i + 1;
        }

        // пульсирующее ядро в центре
        circle(160, 132, R / 6 + 4, 3);

        t = t + 1;
        if (t >= 6144) t = 0;
    }
    return 0;
}
