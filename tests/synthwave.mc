// ============================================================
//   ЗАКАТ-СЕТКА (synthwave) — статичная сцена, рисуется ОДИН раз.
//   Без перерисовки экрана, без vsync, без мандалы.
//
//   Точная перспектива:
//     • горизонтальные линии пола   y = HOR + C/z   (z = 1,2,3...)
//       — сгущаются к горизонту по закону 1/z (как в реале);
//     • вертикальные линии сходятся в точку схода (CX, HOR);
//     • солнце — круг с горизонтальными полосами, утолщающимися книзу.
//   Экран 320x264, цвета графики 0..3.
// ============================================================

int CX;       // центр / точка схода по X
int HOR;      // линия горизонта (Y)
int BOT;      // нижний край пола

// Звёзды (фиксированные координаты — детерминированно, "точно")
int STARX[18] = { 18, 42, 70, 96, 250, 276, 300, 30, 120, 205, 235, 290, 60, 140, 180, 310, 10, 215 };
int STARY[18] = {  8, 24, 14, 40,  10,  30,  18, 52,   6,   8,  44,  58, 70,  60,  46,  64, 38, 72 };

// ── Солнце с горизонтальными прорезями (классический «закат») ──
void drawSun(int cx, int cy, int r, int c) {
    int b;
    int y;
    int t;
    fillCircle(cx, cy, r, c);          // сплошной диск
    // чёрные полосы в нижней половине, толщина растёт вниз
    y = cy - r / 3;
    b = 1;
    while (b <= 6) {
        t = b;                          // толщина полосы = номер
        fill_rect(cx - r, y, r + r, t, 0);
        y = y + t + 3;                  // фиксированный зазор 3px
        b = b + 1;
    }
}

// ── Пол: перспективная сетка ──
void drawFloor() {
    int z;
    int y;
    int C;
    int j;
    int xb;

    C = BOT - HOR;

    // горизонтальные линии — закон 1/z
    z = 1;
    while (z <= 18) {
        y = HOR + C / z;
        line(0, y, 319, y, 1);
        z = z + 1;
    }

    // вертикальные линии — лучи из точки схода к нижнему краю
    j = -8;
    while (j <= 8) {
        xb = CX + j * 20;
        if (xb < 0)   xb = 0;
        if (xb > 319) xb = 319;
        line(CX, HOR, xb, BOT, 1);
        j = j + 1;
    }
}

void drawStars() {
    int i;
    i = 0;
    while (i < 18) {
        point(STARX[i], STARY[i], 3);
        i = i + 1;
    }
}

int main() {
    init(0);
    cls(0);

    CX  = 160;
    HOR = 120;
    BOT = 263;

    drawStars();

    // горизонт — белая черта
    line(0, HOR, 319, HOR, 3);

    // солнце над горизонтом
    drawSun(CX, HOR - 42, 40, 2);

    drawFloor();

    while (1) { }      // картинка статична — просто держим кадр
    return 0;
}
