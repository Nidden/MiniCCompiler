// ============================================================
//   КОЛЬЦА — статичный сплошной тоннель (без обновления экрана).
//   УКНЦ (Электроника МС-0511), графический режим 320x264.
//
//   16 вложенных СПЛОШНЫХ прямоугольников, нарисованных снаружи
//   внутрь (fill_rect — быстрая заливка словами). Каждый меньший
//   перекрывает центр предыдущего, оставляя сплошные цветные
//   рамки → плотный цветной тоннель. Рисуется один раз и замирает
//   (while(1){}), цикла перерисовки нет — мерцать нечему.
//
//   Геометрия точная и симметричная:
//     рамка i:  x=10i, y=8i, w=320-20i, h=264-16i
//   Цвет рамки циклически 1..3.
// ============================================================

int main() {
    int i;
    int c;

    cls(0);

    i = 0;
    while (i < 16) {
        c = (i % 3) + 1;
        fill_rect(10 * i, 8 * i, 320 - 20 * i, 264 - 16 * i, c);
        i = i + 1;
    }

    while (1) { }
    return 0;
}
