// ============================================================
//   ЗАКАТ ЗА ГОРАМИ — статичная сцена (без обновления экрана).
//   УКНЦ (Электроника МС-0511), графический режим 320x264.
//
//   Сюжет, а не абстракция: небо полосами, солнце-диск садится
//   за горизонт, чёрные силуэты гор поверх неба и солнца.
//
//   Всё строится быстрыми пословными заливками fill_rect:
//     • диск солнца — горизонтальными слэбами по уравнению круга
//       x^2 + y^2 <= r^2 (без sqrt, целочисленно);
//     • горы — треугольники: полуширина растёт линейно с высотой.
//   Рисуется ОДИН раз и замирает (while(1){}) — цикла перерисовки
//   нет, экран не трогается, мерцать нечему.
//
//   Цвета 0..3 (аппаратная палитра): 0=фон/силуэт, 1/2/3 — небо
//   и солнце.
// ============================================================

// Залитый диск: для каждой строки dy ищем максимальный xm, что
// (xm)^2 + dy^2 <= r^2, и заливаем горизонтальный слэб.
void disc(int cx, int cy, int r, int col) {
    int dy;
    int xm;
    int r2;
    r2 = r * r;
    dy = 0 - r;
    while (dy <= r) {
        xm = 0;
        while ((xm + 1) * (xm + 1) + dy * dy <= r2) {
            xm = xm + 1;
        }
        fill_rect(cx - xm, cy + dy, xm + xm + 1, 1, col);
        dy = dy + 1;
    }
}

// Залитый треугольник-гора: пик (px, peakY), основание на baseY,
// полуоснование halfBase. Полуширина линейна по высоте.
void mountain(int px, int peakY, int baseY, int halfBase, int col) {
    int y;
    int h;
    int hw;
    h = baseY - peakY;
    y = peakY;
    while (y <= baseY) {
        hw = (y - peakY) * halfBase / h;
        fill_rect(px - hw, y, hw + hw + 1, 1, col);
        y = y + 1;
    }
}

int main() {
    cls(0);

    // ── небо двумя полосами (горизонт на y=170) ──
    fill_rect(0,   0, 320,  90, 1);    // верхнее небо
    fill_rect(0,  90, 320,  80, 3);    // нижнее небо (светлее, у солнца)

    // ── солнце-диск над горизонтом ──
    disc(160, 150, 40, 2);

    // ── земля: накрывает нижнюю часть солнца → оно «садится» ──
    fill_rect(0, 170, 320, 94, 0);

    // ── силуэты гор поверх неба и солнца ──
    mountain( 70,  70, 170,  80, 0);
    mountain(170,  40, 170, 110, 0);
    mountain(250,  90, 170,  70, 0);

    // картинка готова — замираем, экран больше не трогаем
    while (1) { }
    return 0;
}
